# ============================================================
# ReactEscrow — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ============================================================

# --- Wallet (for deployment and scripts) ---
# Your deployer wallet private key (without 0x prefix or with)
PRIVATE_KEY=your_private_key_here

# --- Somnia Testnet RPC ---
# Default: https://dream-rpc.somnia.network/
SOMNIA_RPC_URL=https://dream-rpc.somnia.network/

# --- Deployed Contract Addresses (filled after deployment) ---
REACT_ESCROW_ADDRESS=
REACTIVE_HANDLERS_ADDRESS=

# --- Frontend Environment (Vite) ---
# Copy these to frontend/.env after deployment
VITE_REACT_ESCROW_ADDRESS=
VITE_SOMNIA_RPC_URL=https://dream-rpc.somnia.network/
VITE_CHAIN_ID=50312
VITE_BLOCK_EXPLORER=https://shannon-explorer.somnia.network/

# --- Reactive Service ---
# WebSocket endpoint for Somnia Reactivity (same as RPC, uses wss://)
SOMNIA_WS_URL=wss://dream-rpc.somnia.network/
REACTIVE_SERVICE_PORT=3001
